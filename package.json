{
  "name": "idea-lab-mcp",
  "version": "1.1.0",
  "description": "MCP server for structured ideation — generating, scoring, deduplicating, and storing software ideas",
  "type": "module",
  "main": "build/server.js",
  "bin": {
    "idea-lab-mcp": "build/server.js"
  },
  "files": [
    "build",
    "config",
    "web/dist",
    "src/db/migrations",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mordiaky/idea-lab-mcp.git"
  },
  "homepage": "https://mordiaky.github.io/idea-lab-mcp/",
  "bugs": {
    "url": "https://github.com/mordiaky/idea-lab-mcp/issues"
  },
  "keywords": [],
  "author": "",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc && npm run build:web",
    "build:web": "cd web && npm run build",
    "build:server": "tsc",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.22.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
